# SMTP Email Configuration for Contact Form
# Copy this to .env and replace with YOUR real values
# NEVER commit real credentials!

# Gmail (RECOMMENDED - easiest setup)
EMAIL_USER=yourname@gmail.com
EMAIL_PASS=your16charapppasswordabcd  # ← 16-char app password (NOT regular password!)

# OR Custom SMTP (advanced)
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=yourname@domain.com
# SMTP_PASS=yourpassword

# Optional: Customize sender
EMAIL_FROM_NAME="Your Name or Company"
# EMAIL_FROM=from@yourdomain.com  # overrides EMAIL_USER as sender

